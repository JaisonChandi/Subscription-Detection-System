PORT=5000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=subscription_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Email Configuration (SMTP)
# For Gmail: use smtp.gmail.com, port 587, and an app-specific password
# For Mailtrap: use sandbox.smtp.mailtrap.io with your credentials
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_or_smtp_password

# Frontend URL (for verification email links)
FRONTEND_URL=http://localhost:3000

